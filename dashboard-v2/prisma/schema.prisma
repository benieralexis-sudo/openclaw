// iFIND — Schema Prisma multi-tenant
// Phase 1.3 du plan refonte dashboard
//
// Convention :
// - Tous les modèles "scopés" client ont un `clientId` indexé.
// - User est scopé via clientId (clients) ou scopeClientIds (commerciaux).
// - Soft-delete via `deletedAt` plutôt que DELETE physique.
// - timestamps en UTC, formatés français côté UI.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================================
// AUTH (Better Auth)
// =====================================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  image           String?
  emailVerified   Boolean   @default(false)
  passwordHash    String?
  role            UserRole  @default(CLIENT)
  // Multi-tenant scope
  clientId        String?   // Pour rôle CLIENT/EDITOR/VIEWER : leur unique client
  scopeClientIds  String[]  @default([]) // Pour rôle COMMERCIAL : liste de clients gérés
  client          Client?   @relation("ClientOwner", fields: [clientId], references: [id], onDelete: SetNull)
  // Préférences
  locale          String    @default("fr-FR")
  timezone        String    @default("Europe/Paris")
  preferences     Json?
  // Flags
  onboardingDone  Boolean   @default(false)
  // Audit
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sessions        Session[]
  accounts        Account[]
  notifications   Notification[]
  activities      LeadActivity[]

  @@index([clientId])
  @@index([role])
  @@index([deletedAt])
}

enum UserRole {
  ADMIN       // Voit tout, peut tout faire
  COMMERCIAL  // Voit ses scopeClientIds (commerciaux amis)
  CLIENT      // Voit son seul client
  EDITOR      // Comme CLIENT mais peut éditer
  VIEWER      // Comme CLIENT mais lecture seule
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId        String
  accountId         String
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  password          String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id          String   @id @default(cuid())
  identifier  String
  value       String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([identifier, value])
}

// =====================================================================
// CLIENT (tenant)
// =====================================================================

model Client {
  id          String       @id @default(cuid())
  slug        String       @unique // "digitestlab", "ifind"
  name        String
  legalName   String?
  industry    String?
  region      String?
  size        String?      // "TPE", "PME", "ETI", "GE"
  status      ClientStatus @default(PROSPECT)
  plan        ClientPlan   @default(LEADS_DATA)
  // Branding (optionnel)
  primaryColor String?
  logoUrl      String?
  // Contact
  contactEmail String?
  contactPhone String?
  // ICP config (JSON flexible)
  icp          Json?
  // Metadata
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  activatedAt  DateTime?
  pausedAt     DateTime?
  deletedAt    DateTime?

  users        User[]       @relation("ClientOwner")
  triggers     Trigger[]
  leads        Lead[]
  opportunities Opportunity[]
  campaigns    Campaign[]
  replies      Reply[]
  notifications Notification[]
  rodzSignals   RodzSignal[]

  @@index([status])
  @@index([deletedAt])
}

enum ClientStatus {
  PROSPECT  // Pas encore signé
  ACTIVE    // Signé, en production
  PAUSED    // Suspendu (paiement, demande, ...)
  CHURNED   // Parti
}

enum ClientPlan {
  LEADS_DATA   // 199€/mois
  FULL_SERVICE // 890€/mois
  CUSTOM
}

// =====================================================================
// TRIGGER ENGINE — données métier
// =====================================================================

model Trigger {
  id            String       @id @default(cuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Source (BODACC, INPI, France Travail, etc — interne, pas exposé client)
  sourceCode    String       // "bodacc.levee", "francetravail.head_of_sales", "inpi.marque"
  sourceUrl     String?
  capturedAt    DateTime     @default(now()) // Quand notre moteur l'a vu
  publishedAt   DateTime?    // Quand l'événement public est sorti
  // Entreprise détectée (attribution SIRENE)
  companyName   String
  companySiret  String?      // SIREN/SIRET
  companyNaf    String?
  industry      String?
  region        String?
  size          String?
  // Lecture du signal
  type          TriggerType
  title         String       // "Levée de fonds Série A — 4,5 M€"
  detail        String?      // Description longue
  rawPayload    Json?        // Données brutes de la source
  // Scoring (Claude Opus 4.7)
  score         Int          // 1-10
  scoreReason   String?      // Brief contextuel généré par l'IA
  isHot         Boolean      @default(false) // ≥9
  isCombo       Boolean      @default(false) // pattern combiné (levée + hire ex)
  // Pipeline
  status        TriggerStatus @default(NEW)
  ignoredAt     DateTime?
  ignoredReason String?
  // Enrichment dedup (évite re-fetch Pappers à chaque cron 6h)
  pappersDirigeantsAttemptedAt DateTime?
  // Soft delete
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  lead          Lead?
  opportunity   Opportunity?

  @@index([clientId, status, capturedAt(sort: Desc)])
  @@index([clientId, score(sort: Desc)])
  @@index([clientId, isHot])
  @@index([sourceCode])
  @@index([companySiret])
  @@index([deletedAt])
}

enum TriggerType {
  FUNDRAISING       // Levée de fonds
  HIRING_KEY        // Recrutement clé (Head of X, C-level)
  LEADERSHIP_CHANGE // Changement dirigeant
  TRADEMARK         // Dépôt INPI marque
  PATENT            // Dépôt brevet
  AD_CAMPAIGN       // Campagne pub Meta/LinkedIn
  EXPANSION         // Ouverture site / pays
  REGULATORY        // Changement réglementaire / status
  BUYING_INTENT     // Signal d'achat firmographique (TheirStack searchCompanies)
  CAPITAL_INCREASE  // Augmentation de capital BODACC (signal levée pré-officiel)
  JOB_MOVE          // Dirigeant a changé de poste <6m (Dropcontact job_move)
  OTHER
}

enum TriggerStatus {
  NEW          // À traiter
  CONTACTED    // Email envoyé
  REPLIED      // Réponse reçue
  BOOKED       // RDV pris
  WON          // Deal signé
  LOST         // Perdu
  IGNORED      // Pas pertinent
}

// =====================================================================
// LEAD — contact identifié sur l'entreprise
// =====================================================================

model Lead {
  id            String     @id @default(cuid())
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggerId     String?    @unique
  trigger       Trigger?   @relation(fields: [triggerId], references: [id], onDelete: SetNull)
  // Personne
  firstName     String?
  lastName      String?
  fullName      String?
  jobTitle      String?
  linkedinUrl   String?
  // Contact
  email         String?
  emailStatus   EmailStatus @default(UNVERIFIED)
  phone         String?
  // Entreprise (denormalisé pour requêtes rapides)
  companyName   String
  companySiret  String?
  // Pipeline
  status        LeadStatus @default(NEW)
  enrichedAt    DateTime?  // Quand on a enrichi via Pappers/Dropcontact
  // Brief commercial Opus (généré on-demand, cache 7j)
  briefJson     Json?
  briefGeneratedAt DateTime?
  // Kaspr enrichment (LinkedIn → email pro + tel + titre, cache 7j)
  kasprEnrichedAt     DateTime?
  kasprAttemptedAt    DateTime?  // Pose même si rien trouvé (évite retentatives <30j)
  kasprWorkEmail      String?
  kasprPersonalEmail  String?
  kasprPhone          String?
  kasprTitle          String?
  kasprCreditsUsed    Int?      @default(0)
  kasprResponseJson   Json?
  // Dropcontact dedup — évite ré-essai des "no email found" à chaque cron
  dropcontactAttemptedAt DateTime?
  // Rodz dedup — évite ré-essai des "no LinkedIn match" à chaque cron
  rodzAttemptedAt        DateTime?
  // Multi-source emails (audit qualité Q3, 29/04). On stocke chaque source
  // séparément + un `emailConfidence` calculé pour identifier les emails
  // validés par 2+ sources concordantes (~95% deliverability).
  emailRodz              String?
  emailDropcontact       String?
  emailConfidence        Int      @default(0)  // 0-100 (cf. recompute-email-confidence.ts)
  emailSourceCount       Int      @default(0)  // 0-3 sources renseignées
  // Pappers — données financières + signaux pour scoring richesse
  companyRevenue        Int?     // CA dernier exercice (€)
  companyResultNet      Int?     // Résultat net dernier exercice (€)
  companyHasInsolvency  Boolean  @default(false)  // procédure collective en cours
  companyEtabsCount     Int?     // Nombre d'établissements (multi-sites = expansion)
  companyRecentDepots   Json?    // Dépôts d'actes RCS <90j (nominations, modif. capital)
  // Job moves Dropcontact (signal d'achat — équivalent gratuit Rodz job-changes)
  jobMoveDetected       Boolean  @default(false)
  previousCompany       String?
  previousJob           String?
  // Cache des contenus on-demand (pitch / linkedin DM / call brief) — économie tokens Opus
  pitchJson         Json?
  pitchGeneratedAt  DateTime?
  linkedinDmJson    Json?
  linkedinDmGeneratedAt DateTime?
  callBriefJson     Json?
  callBriefGeneratedAt DateTime?
  // Audit
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  opportunities  Opportunity[]
  replies        Reply[]
  emailActivity  EmailActivity[]
  emailEvents    EmailEvent[]
  activities     LeadActivity[]

  @@index([clientId, status, createdAt(sort: Desc)])
  @@index([email])
  @@index([companySiret])
  @@index([deletedAt])
}

enum EmailStatus {
  UNVERIFIED
  VALID
  RISKY
  INVALID
  BOUNCED
}

enum LeadStatus {
  NEW
  ENRICHED
  CONTACTABLE
  CONTACTED
  NOT_INTERESTED
  ARCHIVED
}

// =====================================================================
// OPPORTUNITY — pipeline RDV / deal
// =====================================================================

model Opportunity {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  triggerId     String?          @unique
  trigger       Trigger?         @relation(fields: [triggerId], references: [id], onDelete: SetNull)
  // Stage
  stage         OpportunityStage @default(IDENTIFIED)
  // Meeting
  meetingDate   DateTime?
  meetingUrl    String?
  meetingNotes  String?
  // Deal
  dealValueEur  Decimal?         @db.Decimal(12, 2)
  closedAt      DateTime?
  wonAt         DateTime?
  lostAt        DateTime?
  lostReason    String?
  // Assigné
  assignedToUserId String?
  // Audit
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([clientId, stage, updatedAt(sort: Desc)])
  @@index([assignedToUserId])
  @@index([meetingDate])
  @@index([deletedAt])
}

enum OpportunityStage {
  IDENTIFIED   // Trigger reçu, lead identifié
  CONTACTED    // Email envoyé
  ENGAGED      // Réponse positive
  MEETING_SET  // RDV booké
  PROPOSAL     // En proposition
  WON
  LOST
}

// =====================================================================
// CAMPAIGN — séquences cold email (Full Service)
// =====================================================================

model Campaign {
  id            String         @id @default(cuid())
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  status        CampaignStatus @default(DRAFT)
  // Smartlead binding
  externalId    String?        // ID dans Smartlead
  // Stats agrégées
  sent          Int            @default(0)
  opened        Int            @default(0)
  replied       Int            @default(0)
  bookedMeeting Int            @default(0)
  bounced       Int            @default(0)
  // Audit
  startedAt     DateTime?
  pausedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  replies       Reply[]

  @@index([clientId, status])
  @@index([deletedAt])
}

enum CampaignStatus {
  DRAFT
  WARMUP
  RUNNING
  PAUSED
  ARCHIVED
}

// =====================================================================
// REPLY — Unibox unifié
// =====================================================================

model Reply {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaignId   String?
  campaign     Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  // Contenu
  fromEmail    String
  fromName     String?
  subject      String?
  body         String
  bodyHtml     String?
  receivedAt   DateTime    @default(now())
  // Catégorisation IA
  intent       ReplyIntent @default(UNCLASSIFIED)
  intentConfidence Decimal? @db.Decimal(3, 2)
  // Pipeline
  status       ReplyStatus @default(UNREAD)
  assignedToUserId String?
  respondedAt  DateTime?
  // Audit
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([clientId, status, receivedAt(sort: Desc)])
  @@index([clientId, intent])
  @@index([deletedAt])
}

enum ReplyIntent {
  POSITIVE_INTEREST
  REQUEST_INFO
  ASK_TIMING
  OBJECTION
  REFUSED
  OUT_OF_OFFICE
  UNSUBSCRIBE
  WRONG_PERSON
  UNCLASSIFIED
}

enum ReplyStatus {
  UNREAD
  READ
  RESPONDING
  ANSWERED
  ARCHIVED
}

// =====================================================================
// NOTIFICATION
// =====================================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Contenu
  type        String   // "trigger.hot", "reply.positive", "system.alert"
  title       String
  body        String?
  payload     Json?
  link        String?
  // État
  readAt      DateTime?
  // Audit
  createdAt   DateTime @default(now())

  @@index([userId, readAt])
  @@index([clientId, createdAt(sort: Desc)])
}

// =====================================================================
// AUDIT LOG (admin)
// =====================================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  clientId    String?
  action      String   // "client.created", "trigger.scored", "user.login"
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([clientId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

// =====================================================================
// EMAIL ACTIVITY — historique cold email manuel + replies IMAP
// =====================================================================
// SENT     : un commercial a cliqué "Envoyer email" depuis le dashboard
// RECEIVED : un poller IMAP (skills/trigger-engine/lib/mailbox-poller.js)
//            a détecté un reply matchant un Lead.email
// Le messageId est dédupliqué via @unique pour éviter doublons sur replays.

model EmailActivity {
  id              String      @id @default(cuid())
  leadId          String
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction       EmailDirection
  fromMailbox     String      // user@domain (notre mailbox côté SENT, sender côté RECEIVED)
  toEmail         String      // destinataire (le lead côté SENT, notre mailbox côté RECEIVED)
  subject         String
  bodyText        String?     @db.Text
  bodyHtml        String?     @db.Text
  messageId       String?     @unique // SMTP Message-ID header
  inReplyTo       String?     // Message-ID auquel on répond
  sentAt          DateTime    @default(now()) // = receivedAt côté RECEIVED
  sentByUserId    String?     // Better Auth User id (NULL si reçu)
  template        String?     // 'pitch' | 'linkedin-dm' | 'call-brief' | 'manual'
  replyClassification String? // 'positive' | 'neutral' | 'negative' | 'ooo' | 'unsubscribe' (Haiku)
  replyClassifiedAt DateTime?
  createdAt       DateTime    @default(now())

  @@index([leadId, sentAt(sort: Desc)])
  @@index([fromMailbox, sentAt(sort: Desc)])
  @@index([direction, sentAt(sort: Desc)])
}

enum EmailDirection {
  SENT
  RECEIVED
}

// Tracking événements email Resend (opens / clicks / bounces / complaints).
// Permet d'identifier les leads "warm" (3+ opens = signal d'intérêt).
model EmailEvent {
  id          String           @id @default(cuid())
  leadId      String?
  lead        Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  emailId     String?          // Resend email_id si dispo
  recipient   String           // email destinataire
  type        EmailEventType
  occurredAt  DateTime         @default(now())
  metadata    Json?            // user agent, IP city, click URL, bounce code, etc.
  createdAt   DateTime         @default(now())

  @@index([leadId, occurredAt(sort: Desc)])
  @@index([recipient, type, occurredAt(sort: Desc)])
  @@index([emailId])
}

enum EmailEventType {
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
}

// =====================================================================
// LEAD ACTIVITY — table unifiée multi-canal (email/LinkedIn/appel/RDV/note)
// Permet timeline temps réel + compteurs par lead + stats agrégées par
// commercial. Auto (bot/webhook) + manuel (commercial coche/log).
// =====================================================================

model LeadActivity {
  id              String          @id @default(cuid())
  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId        String           // denorm pour stats par client
  type            ActivityType
  source          ActivitySource
  direction       ActivityDirection
  occurredAt      DateTime         @default(now())
  userId          String?          // commercial qui a fait l'action (null si bot/webhook)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Liens facultatifs vers entités existantes (compat ascendante)
  emailActivityId String?          // ref EmailActivity si type=EMAIL_*
  emailEventId    String?          // ref EmailEvent si OPEN/CLICK/BOUNCE
  opportunityId   String?          // ref Opportunity si MEETING_*
  // Données libres (subject, body excerpt, durée appel, message LinkedIn, note...)
  payload         Json?
  createdAt       DateTime         @default(now())

  @@index([leadId, occurredAt(sort: Desc)])
  @@index([clientId, type, occurredAt(sort: Desc)])
  @@index([userId, occurredAt(sort: Desc)])
}

enum ActivityType {
  EMAIL_SENT
  EMAIL_REPLY
  EMAIL_OPEN
  EMAIL_CLICK
  EMAIL_BOUNCE
  LINKEDIN_DM_SENT
  LINKEDIN_DM_REPLY
  LINKEDIN_VIEW_PROFILE
  LINKEDIN_CONNECT
  CALL_OUTBOUND
  CALL_INBOUND
  VOICEMAIL_LEFT
  MEETING_BOOKED
  MEETING_HELD
  MEETING_NO_SHOW
  NOTE
  STATUS_CHANGE
}

enum ActivitySource {
  AUTO          // bot interne (qualify, brief, pipelines)
  WEBHOOK       // Resend, Cal.com, IMAP poller
  MANUAL        // commercial coche / clique
  GMAIL_API     // futur — auto-detect Gmail Sent
}

enum ActivityDirection {
  OUTBOUND
  INBOUND
}

// =====================================================================
// RODZ SIGNAL — tracking des monitors Rodz créés par client
// =====================================================================

model RodzSignal {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Référence Rodz
  rodzSignalId    String   @unique
  signalType      String   // "fundraising", "job-changes", "mergers-acquisitions", ...
  name            String
  webhookUrl      String
  // Config envoyée à Rodz (filtres ICP, keywords, ...)
  config          Json
  dailyLeadLimit  Int?
  // État
  status          String   @default("draft") // "draft", "active", "paused"
  active          Boolean  @default(false)
  // Métriques
  leadsReceived   Int      @default(0)
  creditsUsed     Decimal  @default(0) @db.Decimal(10, 2)
  lastLeadAt      DateTime?
  // Audit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([clientId, active])
  @@index([signalType])
  @@index([deletedAt])
}
