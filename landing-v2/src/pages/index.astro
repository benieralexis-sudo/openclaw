---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SocialProof from "../components/SocialProof.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import FinalCta from "../components/FinalCta.astro";

const title = "iFIND — Trigger Engine FR · Détection de signaux d'achat temps réel";
const description =
  "iFIND détecte en temps réel les PME françaises qui déclenchent un besoin d'achat (levée de fonds, recrutement clé, dépôt INPI, nouveau dirigeant). Attribution SIRET vérifiée, scoring par Claude Opus 4.7, brief contextuel par lead. Leads Data 199€/mois ou Full Service 890€/mois, sans engagement.";

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name: "iFIND",
      alternateName: "Trigger Engine FR",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      description: "Moteur SaaS de détection de signaux d'achat temps réel sur les PME françaises.",
      offers: [
        {
          "@type": "Offer",
          name: "Leads Data",
          price: "199",
          priceCurrency: "EUR",
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            price: "199",
            priceCurrency: "EUR",
            unitText: "MONTH",
          },
          availability: "https://schema.org/InStock",
          url: "https://ifind.fr/leads-data",
        },
        {
          "@type": "Offer",
          name: "Full Service",
          price: "890",
          priceCurrency: "EUR",
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            price: "890",
            priceCurrency: "EUR",
            unitText: "MONTH",
          },
          availability: "https://schema.org/InStock",
          url: "https://ifind.fr/full-service",
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "En quoi un trigger est-il différent de l'intent data classique ?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "L'intent data mesure des signaux de recherche web (probabilité). Un trigger est un événement public dur (levée de fonds, dépôt INPI, recrutement) — un fait, pas une probabilité.",
          },
        },
        {
          "@type": "Question",
          name: "Quelles sources surveillez-vous ?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Toutes les annonces officielles publiées en France, les offres d'emploi qui révèlent une stratégie, les dépôts de marque et les signaux de croissance numérique. Sources publiques officielles uniquement.",
          },
        },
        {
          "@type": "Question",
          name: "Combien de leads vais-je recevoir ?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Aucun plafond, aucun remplissage. Vous recevez chaque lead qui matche votre ICP au moment où il devient chaud. Selon votre niche, ça peut être 30 leads/mois ultra-ciblés ou 200 si votre marché est large.",
          },
        },
        {
          "@type": "Question",
          name: "Puis-je résilier à tout moment ?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Oui. Sans engagement annuel, préavis 30 jours.",
          },
        },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={homeSchema}>
  <Hero />
  <SocialProof />
  <Problem />
  <HowItWorks />
  <Pricing />
  <Faq />
  <FinalCta />
</BaseLayout>
