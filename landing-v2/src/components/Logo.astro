---
interface Props {
  variant?: "dark" | "white";
  size?: "sm" | "md" | "lg";
}

const { variant = "dark", size = "md" } = Astro.props;

const sizes = {
  sm: { wrap: "h-6", text: "text-base" },
  md: { wrap: "h-7", text: "text-[1.125rem]" },
  lg: { wrap: "h-9", text: "text-2xl" },
};

const colorClass = variant === "white" ? "text-white" : "text-ink";
const dotColor = variant === "white" ? "bg-white" : "bg-primary-600";
---

<span class={`inline-flex items-center gap-2 font-display ${colorClass}`}>
  <!-- Mark : un cercle creux + un point centré (signal détecté) -->
  <svg
    viewBox="0 0 28 28"
    class={sizes[size].wrap + " w-auto"}
    fill="none"
    aria-hidden="true"
  >
    <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.6" opacity="0.18" />
    <circle cx="14" cy="14" r="8" stroke="currentColor" stroke-width="1.6" opacity="0.4" />
    <circle cx="14" cy="14" r="4" fill="currentColor" />
    <circle cx="22.5" cy="6.5" r="2.5" fill="#10b981" />
    <circle cx="22.5" cy="6.5" r="2.5" fill="#10b981">
      <animate attributeName="r" values="2.5;3.4;2.5" dur="2.5s" repeatCount="indefinite" />
      <animate attributeName="opacity" values="1;0.4;1" dur="2.5s" repeatCount="indefinite" />
    </circle>
  </svg>
  <span class={`${sizes[size].text} font-semibold tracking-tight`}>iFIND</span>
</span>
