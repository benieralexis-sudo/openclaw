---
interface Props {
  variant?: "dark" | "white";
  size?: "sm" | "md" | "lg";
}

const { variant = "dark", size = "md" } = Astro.props;

const sizes = {
  sm: { mark: "h-6", text: "text-base" },
  md: { mark: "h-7", text: "text-[1.125rem]" },
  lg: { mark: "h-9", text: "text-2xl" },
};

const colorClass = variant === "white" ? "text-white" : "text-ink";
---

<span class={`inline-flex items-center gap-2 font-display ${colorClass}`}>
  <svg
    viewBox="0 0 32 32"
    class={`${sizes[size].mark} w-auto shrink-0`}
    fill="none"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="ifindLogoGrad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
        <stop stop-color="#2D4EF5" />
        <stop offset="1" stop-color="#1F37B3" />
      </linearGradient>
    </defs>
    <rect width="32" height="32" rx="7" fill="url(#ifindLogoGrad)" />
    <text
      x="16"
      y="22"
      text-anchor="middle"
      font-family="Inter, ui-sans-serif, system-ui, sans-serif"
      font-size="18"
      font-weight="700"
      fill="white"
      letter-spacing="-0.04em"
    >iF</text>
    <circle cx="25" cy="7" r="3" fill="#10b981" stroke="white" stroke-width="1.4" />
  </svg>
  <span class={`${sizes[size].text} font-semibold tracking-tight`}>iFIND</span>
</span>
