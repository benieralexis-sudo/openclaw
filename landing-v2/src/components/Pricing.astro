---
const offers = [
  {
    name: "Leads Data",
    price: "199",
    period: "€/mois",
    tagline: "Vos leads qualifiés en flux continu, vous gérez l'outbound.",
    href: "/leads-data",
    cta: "Démarrer Leads Data",
    ctaTally: "https://tally.so/r/RGZ5JP",
    recommended: false,
    icon: "data",
    inclusions: [
      { text: "Jusqu'à 500 leads qualifiés / mois", bold: true },
      { text: "9 sources publiques FR surveillées" },
      { text: "Score ≥ 7/10 garanti" },
      { text: "Attribution SIRENE premium (Pappers)" },
      { text: "Brief contextuel par lead" },
      { text: "Dashboard temps réel app.ifind.fr" },
      { text: "Alertes pépites + digest hebdo" },
      { text: "Export CSV / API webhook" },
    ],
    notIncluded: ["Envoi des emails", "Booking RDV", "Mailboxes & warmup"],
    forWho: "Équipes sales internalisées qui ont déjà leur stack outbound.",
  },
  {
    name: "Full Service",
    price: "890",
    period: "€/mois",
    tagline: "On détecte, on contacte, on book le RDV. Vous closez.",
    href: "/full-service",
    cta: "Démarrer Full Service",
    ctaTally: "https://tally.so/r/QKYA6Y",
    recommended: true,
    icon: "service",
    inclusions: [
      { text: "Tout le pack Leads Data inclus", bold: true },
      { text: "Domaine + 3 mailboxes warmup" },
      { text: "Cold email automatisé Smartlead" },
      { text: "Réponses gérées par notre commercial" },
      { text: "Booking de RDV sur votre Cal.com" },
      { text: "Reporting hebdo détaillé" },
      { text: "Suivi performance ICP" },
      { text: "Anti-bounce MillionVerifier" },
    ],
    notIncluded: ["Closing du deal (vous restez maître)"],
    forWho: "Founders / heads of sales qui veulent un canal outbound clé en main.",
  },
];
---

<section id="offres" class="section">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow reveal">Offres</p>
      <h2 class="reveal mt-3 text-3xl font-bold tracking-tight md:text-4xl">
        Deux formules. Pas de devis. Pas de palier caché.
      </h2>
      <p class="reveal mx-auto mt-4 text-lg text-ink-soft">
        Vous gérez déjà votre outbound ? Prenez la data brute.
        Vous voulez juste des RDV qualifiés ? On s'occupe de tout jusqu'au booking.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-6 md:grid-cols-2">
      {
        offers.map((o) => (
          <article
            class={`reveal relative flex flex-col rounded-2xl border p-8 transition-all ${
              o.recommended
                ? "border-primary-300 bg-white shadow-glow ring-1 ring-primary-200"
                : "border-border bg-white"
            }`}
          >
            {o.recommended && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white shadow-md">
                  Recommandé
                </span>
              </div>
            )}

            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-2xl font-bold text-ink">{o.name}</h3>
                <p class="mt-1 text-sm text-ink-soft">{o.tagline}</p>
              </div>
            </div>

            <div class="mt-6 flex items-baseline gap-1.5">
              <span class="font-display text-5xl font-bold tracking-tight text-ink">
                {o.price}
              </span>
              <span class="text-ink-soft">{o.period}</span>
            </div>
            <p class="mt-1 text-xs text-ink-muted">HT · sans engagement · résiliable à tout moment</p>

            <a
              href={o.ctaTally}
              target="_blank"
              rel="noopener"
              class={`mt-6 ${o.recommended ? "btn btn-primary btn-lg w-full" : "btn btn-ghost btn-lg w-full"}`}
            >
              {o.cta}
            </a>

            <a href={o.href} class="mt-3 text-center text-sm font-medium text-primary-600 hover:text-primary-700">
              Voir le détail →
            </a>

            <div class="mt-7 border-t border-border pt-6">
              <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-ink-muted">
                Inclus
              </p>
              <ul class="space-y-2.5 text-sm">
                {o.inclusions.map((i) => (
                  <li class="flex items-start gap-2.5">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span class={i.bold ? "font-medium text-ink" : "text-ink-soft"}>{i.text}</span>
                  </li>
                ))}
              </ul>

              {o.notIncluded.length > 0 && (
                <>
                  <p class="mt-6 mb-3 text-xs font-semibold uppercase tracking-wider text-ink-muted">
                    Non inclus
                  </p>
                  <ul class="space-y-2 text-sm">
                    {o.notIncluded.map((n) => (
                      <li class="flex items-start gap-2.5 text-ink-faint">
                        <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                          <path d="M18 6 6 18M6 6l12 12" />
                        </svg>
                        <span>{n}</span>
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </div>

            <div class="mt-6 rounded-lg bg-surface-soft p-4 text-sm text-ink-soft">
              <strong class="font-medium text-ink">Pour qui :</strong> {o.forWho}
            </div>
          </article>
        ))
      }
    </div>

    <p class="mx-auto mt-10 max-w-xl text-center text-sm text-ink-muted">
      Tarifs early-stage. Garantis 12 mois pour les premiers clients.
    </p>
  </div>
</section>
