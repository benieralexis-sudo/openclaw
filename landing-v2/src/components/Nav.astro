---
import Logo from "./Logo.astro";

const links = [
  { href: "/#fonctionnement", label: "Fonctionnement" },
  { href: "/#offres", label: "Offres" },
  { href: "/#faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-40 border-b border-border/60 bg-surface/85 backdrop-blur-md backdrop-saturate-150">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2 font-display font-semibold text-ink" aria-label="iFIND — Accueil">
      <Logo />
    </a>

    <nav class="hidden items-center gap-7 text-sm text-ink-soft md:flex" aria-label="Navigation principale">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="transition-colors hover:text-ink"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="/#offres" class="btn btn-primary text-sm shadow-sm">
        Démarrer
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</header>
