{
  "id": "tech-hiring",
  "name": "Tech hiring — entreprise qui recrute tech",
  "description": "Entreprise qui publie au moins 1 offre tech + au moins 1 autre offre. Signal d'équipe tech qui grandit — besoin QA, DevOps, cyber, infra.",
  "verticaux": ["qa", "cyber", "devops", "saas-dev", "infra"],
