  "min_score": 5.5,
  "max_score": 10.0,
  "window_days": 30,
  "signals_required": {
    "must_have_at_least_one_of": [
      {
        "types": ["hiring_tech"],
        "min_count": 1,
        "weight": 4.0,
        "description": "Au moins 1 offre tech"
      },
      {
        "types": ["hiring_tech", "hiring_sales", "hiring_marketing", "hiring_executive", "hiring_finance", "hiring_hr", "hiring_other"],
        "min_count": 2,
        "weight": 2.0,
        "description": "Au moins 2 offres total (diversité)"
      }
    ]
  },
  "bonuses": [
    {
      "types": ["hiring_tech"],
      "weight": 1.5,
      "description": "Bonus par offre tech supplémentaire"
    },
    {
      "types": ["funding"],
      "weight": 2.0,
      "description": "Bonus levée de fonds"
    }
  ],
  "exclusions": [
    {
      "types": ["procedure_collective", "company_cessation"]
    }
  ],
  "enabled": true
}
