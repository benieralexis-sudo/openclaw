!flowfast/
!flowfast/**
!automailer/
!automailer/**
!autonomous-pilot/
!autonomous-pilot/**
!crm-pilot/
!crm-pilot/**
!inbox-manager/
!inbox-manager/**
!invoice-bot/
!invoice-bot/**
!lead-enrich/
!lead-enrich/**
!meeting-scheduler/
!meeting-scheduler/**
!self-improve/
!self-improve/**
!system-advisor/
!system-advisor/**
!proactive-agent/
!proactive-agent/**
!web-intelligence/
!web-intelligence/**
!precall-brief/
!precall-brief/**
!trigger-engine/
