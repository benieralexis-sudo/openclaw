# Ignorer les fichiers temporaires
*.save
*.backup

# Ignorer les data runtime (generees par les skills a chaque cycle)
*/data/
*/data/**

# Ignorer les node_modules dans chaque skill (geres par pnpm workspaces root)
*/node_modules/
*/node_modules/**
