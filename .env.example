# ═══════════════════════════════════════════════════════════════════
# iFIND Trigger Engine v2.0 — Variables d'environnement
# Copier vers .env et remplir avec tes vraies valeurs.
# Toutes les clés marquées [requis] sont nécessaires au boot du bot.
# Les clés [opt-in] activent une fonctionnalité spécifique.
# ═══════════════════════════════════════════════════════════════════

# ───── TELEGRAM (requis) ─────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
ADMIN_CHAT_ID=1409505520

# ───── IA PROVIDERS (requis) ─────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY     # GPT-4o-mini routing Telegram
CLAUDE_API_KEY=REPLACE_WITH_ANTHROPIC_KEY  # Opus 4.7 + Sonnet 4.6 (alias toléré: ANTHROPIC_API_KEY)

# ───── EMAIL SENDING (requis pour digest hebdo + alertes pépites) ─────
RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
RESEND_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
SENDER_EMAIL=hello@ifind.fr
# Le domaine SENDER_EMAIL doit être VERIFIED côté Resend.

# ───── IMAP / INBOX MANAGER (requis pour replies feedback loop) ─────
IMAP_HOST=imap.ionos.fr
IMAP_USER=hello@ifind.fr
IMAP_PASS=REPLACE_WITH_IMAP_PASSWORD

# ───── DASHBOARD MISSION CONTROL (requis) ─────
DASHBOARD_PASSWORD=REPLACE_WITH_BCRYPT_HASH

# ───── TRIGGER ENGINE — SOURCES FR (recommandé) ─────
# Sources gratuites (pas de clé) : BODACC, Maddyness/Frenchweb RSS, JOAFE, SIRENE
# Sources avec auth :
PAPPERS_API_TOKEN=REPLACE_WITH_PAPPERS_TOKEN          # Attribution SIRENE premium + bilans + dirigeants (75€/mois)
DROPCONTACT_API_KEY=REPLACE_WITH_DROPCONTACT_KEY      # Email finder FR 94% match GDPR-by-design (79€/mois)
FRANCETRAVAIL_CLIENT_ID=REPLACE_WITH_FT_CLIENT_ID     # OAuth API gratuite hiring signals FR
FRANCETRAVAIL_CLIENT_SECRET=REPLACE_WITH_FT_SECRET
INPI_USERNAME=REPLACE_WITH_INPI_USER                  # Marques INPI (compte gratuit)
INPI_PASSWORD=REPLACE_WITH_INPI_PASS
META_AD_LIBRARY_TOKEN=REPLACE_WITH_META_AD_TOKEN      # Ads concurrents Meta (compte dev gratuit)

# ───── STACK B2B 2026 (à brancher après achat) ─────
# RODZ_API_KEY=                       # 14 signaux temps réel FR (50€/mois PAYG)
# THEIRSTACK_API_KEY=                 # Jobs API global dedup (89€/mois)
# TRIGIFY_API_KEY=                    # LinkedIn engagement signals (~$80 PAYG)
# DATAGMA_API_KEY=                    # Mobiles décideurs FR ($39/mois)
# MILLIONVERIFIER_API_KEY=            # Email anti-bounce pre-send (~20€/mois)
# APIFY_API_TOKEN=                    # Scrapers Glassdoor/Reddit/HN (declarative pain)
# SMARTLEAD_API_KEY=                  # Cold email Full Service (séquenceur multi-tenant)
# FOLK_API_KEY=                       # CRM pipeline multi-tenant (22€/mois)
# AIRCALL_API_ID=                     # VoIP cold call B2B
# AIRCALL_API_TOKEN=

# ───── GOOGLE CALENDAR (booking RDV) ─────
GOOGLE_BOOKING_URL=REPLACE_WITH_GOOGLE_BOOKING_URL
# Optionnel — sync API directe :
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ───── CRM (Folk CRM lundi — remplace HubSpot) ─────
# FOLK_API_KEY=REPLACE_WITH_FOLK_KEY

# ───── BUDGET & LIMITES ─────
API_DAILY_BUDGET=5
# Budget USD/jour, stop auto si dépassé.

# ───── BOOSTERS V1.1 (toggle, défauts ON) ─────
COMBO_BOOSTER_ENABLED=true            # Score ×2.5 sur 3 signaux durs <90j
HOT_TRIGGERS_ENABLED=true             # Boost +0.5/+1.0 sur signaux <48h/<24h
DECLARATIVE_PAIN_ENABLED=false        # Détection douleur Opus (opt-in, requiert source amont)

# ───── MONITORING ─────
SENTRY_DSN=
NODE_ENV=production

# ───── WEBHOOKS EXTERNES (HMAC + replay protection actifs) ─────
RODZ_WEBHOOK_SECRET=                  # Webhook Rodz vers Trigger Engine
TALLY_API_KEY=                        # Tally formulaires signup clients

# ───── NOTIFICATIONS ─────
NOTIFY_POSITIVE_EMAILS=               # CSV emails à notifier sur reply positive

# ───── TRIGGER ENGINE TOGGLE ─────
TRIGGER_ENGINE_ENABLED=true           # Active la skill Trigger Engine au boot
