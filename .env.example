# ═══════════════════════════════════════════════════════════════════
# iFIND Bot v9.5 — Variables d'environnement
# Copier vers .env et remplir avec tes vraies valeurs
# ═══════════════════════════════════════════════════════════════════

# ───── TELEGRAM (requis) ─────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
ADMIN_CHAT_ID=1409505520

# ───── IA PROVIDERS (requis) ─────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY
CLAUDE_API_KEY=REPLACE_WITH_ANTHROPIC_KEY
# Alias toléré : ANTHROPIC_API_KEY (même valeur)

# ───── EMAIL SENDING (requis) ─────
RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
RESEND_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
SENDER_EMAIL=hello@ifind.fr
# Domaine Resend doit etre VERIFIED

# ───── IMAP / INBOX MANAGER (requis pour reply feedback) ─────
IMAP_HOST=imap.ionos.fr
IMAP_USER=hello@ifind.fr
IMAP_PASS=REPLACE_WITH_IMAP_PASSWORD

# ───── INSTANTLY (campagnes email automatisees) ─────
INSTANTLY_API_KEY=REPLACE_WITH_INSTANTLY_KEY
INSTANTLY_CAMPAIGN_ID=REPLACE_WITH_CAMPAIGN_ID

# ───── ENRICHMENT ─────
FULLENRICH_API_KEY=REPLACE_WITH_FULLENRICH_KEY
# PAPPERS_API_TOKEN=REPLACE_WITH_PAPPERS (a ajouter pour Trigger Engine)
# DROPCONTACT_API_KEY=REPLACE_WITH_DROPCONTACT (a ajouter pour Trigger Engine)

# ───── CRM HUBSPOT ─────
HUBSPOT_API_KEY=REPLACE_WITH_HUBSPOT_KEY

# ───── GOOGLE CALENDAR (Meeting Scheduler) ─────
GOOGLE_BOOKING_URL=REPLACE_WITH_GOOGLE_BOOKING_URL
# Optionnels — sync API directe (sinon juste le lien suffit) :
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CLIENT_ID=REPLACE_WITH_OAUTH_CLIENT_ID
# GOOGLE_CLIENT_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET
# GOOGLE_REFRESH_TOKEN=REPLACE_WITH_REFRESH_TOKEN

# ───── DASHBOARD MISSION CONTROL ─────
DASHBOARD_PASSWORD=REPLACE_WITH_BCRYPT_HASH
AUTOMAILER_DASHBOARD_PASSWORD=REPLACE_WITH_BCRYPT_HASH

# ───── BUDGET & LIMITES ─────
API_DAILY_BUDGET=5
# En USD, stop auto si depasse (defaut 5$/jour)

# ───── MONITORING (optionnel mais recommande) ─────
SENTRY_DSN=
# Format attendu : REPLACE_WITH_SENTRY_DSN (laisser vide si desactive)
NODE_ENV=production

# ───── MULTI-TENANT (Phase B, optionnel selon client) ─────
# Chaque client a son propre .env dans clients/{client_id}/.env
# Variables specifiques par tenant (credentials isolation)

# ───── WEBHOOKS EXTERNES (HMAC + replay protection actifs) ─────
PHAROW_WEBHOOK_SECRET=
RODZ_WEBHOOK_SECRET=
CLAY_WEBHOOK_SECRET=
# Clay : utilisation en review pour Trigger Engine FR (possible deprecation)

# ───── CLAY (legacy — statut en revue) ─────
# CLAY_API_KEY=
# CLAY_TABLE_ID=
# CLAY_SESSION_COOKIE=

# ───── NOTIFICATIONS ─────
NOTIFY_POSITIVE_EMAILS=

# ═══════════════════════════════════════════════════════════════════
# Variables a ajouter lors de la mise en place TRIGGER ENGINE FR :
# ═══════════════════════════════════════════════════════════════════
# PAPPERS_API_TOKEN=                    (attribution SIRENE)
# DROPCONTACT_API_KEY=                  (enrichment email FR)
# RODZ_API_KEY=                         (signals FR natifs)
# APIFY_API_TOKEN=                      (scrapers WTTJ + LinkedIn)
# THEIRSTACK_API_KEY=                   (tech signals + jobs)
# TRIGIFY_API_KEY=                      (social listening)
# PRIMEFORGE_API_KEY=                   (mailboxes Google/MS)
# WARMFORGE_API_KEY=                    (warmup automatise)
# SMARTLEAD_API_KEY=                    (cadence tool)
# FOLK_API_KEY=                         (CRM)
# SALESNAV_SESSION_COOKIE=              (Sales Nav par client)
# AIRCALL_API_ID= + AIRCALL_API_TOKEN=  (cold call)
# FRANCETRAVAIL_CLIENT_ID= + SECRET=    (API offres emploi FR gratuit)
